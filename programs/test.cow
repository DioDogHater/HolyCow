#include "../std/stdlib.hcw"
#include "../std/linux/unistd.hcw"

double FP_PRECISION = 0.0001;

// Prints a frame around lines of text (with a title)
void frame(char* title = "", ...count){
    // Variable arguments (should all be strings)
    char** vargs = (char**) VARGS;

    // Length of longest string in frame
    uint max_len = strlen(title);

    // Measure each string's length
    uint i = 0;
    repeat(count){
        uint len = strlen(vargs[i]);
        if(len > max_len)
            max_len = len;
        i++;
    }

    // Add 4 characters of padding (2 on both sides)
    max_len += 4;

    // Print top of frame
    if(*title == 0)
        println("+%*c+", max_len, '-');
    // If there's a title, print it centered at the top
    else
        println("+%[ %s %*C+", title, max_len, '-');
    // Print each line of the frame
    repeat(count){
        println("|%[ %s%L|", *vargs, max_len);
        vargs += 8;
    }
    // Print bottom of the frame
    println("+%*c+", max_len, '-');
}

variant msg_data {
    char* text;
    int integer;
    float number;
    bool confirm;
}

class msg {
    // Can only be changed inside msg's methods
    // but can be read / pointed to from anywhere. (@peek)
    private @peek msg_data data = msg_data.integer{ 0 };

    // Setters
    void set_text(char* txt){
        this.data = msg_data.text{ txt };
    }
    void set_integer(int i){
        this.data = msg_data.integer{ i };
    }
    void set_number(float n){
        this.data = msg_data.number{ n };
    }
    void set_confirm(bool b){
        this.data = msg_data.confirm{ b };
    }

    // Test
    void print(){
        if(this.data.type == msg_data.text)
            println("msg{\"%s\"}", this.data.text);
        else if(this.data.type == msg_data.integer)
            println("msg{%i}", this.data.integer);
        else if(this.data.type == msg_data.number)
            println("msg{%f}", this.data.number);
        else if(this.data.type == msg_data.confirm)
            println("msg{%b}", this.data.confirm);
        else
            println("msg{INVALID}");
    }
}

struct test;

struct test2 {
    char* msg1;
    char* msg2;
}

struct test {
    int x = 0;
    int y = 0;
    test2 z;
}

// More procedural approach to objects, while still
// retaining the organisation and encapsulation aspects of classes
module test {
    void greet(){
        println("Hello world!");
    }

    test get(){
        // When a function returns a struct,
        // @return is a pointer to the returned struct
        @return.x = 12345;
        @return.y = 256;
        @return.z = test2{ "Foo", "Bar" };
    }

    // Yes, modules support encapsulation.
    // Private and protected both make variables and functions
    // only accessible from within the module itself.
    private void print_test2(test2 t){
        print("test2{\"%s\", \"%s\"}", t.msg1, t.msg2);
    }

    void print(test t){
        print("test{%u, %u, ", t.x, t.y);
        test.print_test2(t.z);
        println("}");
    }
}

// Nothing stops you from adding stuff in classes already defined
// So hell yeah add whatever extension your want
class string {
    // Prints debug info of the string object
    void print_debug(){
        println("(\"%S\", is_heap=%b, is_shared=%b)", this, this.is_heap(), this.is_shared());
    }
}

void print_int_vector(vector* v){
    print("[");
    for(int i = 0; i < v.size; i++){
        if(i)
            print(", ");
        int* elem = v.at(i);
        print("%i", *elem);
    }
    println("]");
}

class Parent {
    private int priv = 0;
    protected int prot = 0;
    public int pub = 0;

    void print(){
        println("%i, %i, %i", this.priv, this.prot, this.pub);
    }
}

class Child : Parent virtual {
    void print(){
        super.print();
        println("Hello from Child!");
    }

    virtual void test(){
        println("Test from Child");
    }
}

class Child2 : Child virtual {
    virtual void test(){
        println("Test from Child2");
    }
}

class OperatorTest {
    int x;

    int __add_int(int x){
        return this.x + x;
    }

    int __mul_float(double x){
        return (double)(this.x * x);
    }

    int __div_OperatorTest(OperatorTest b){
        return this.x / b.x;
    }

    int __neg(){
        return -this.x;
    }

    bool __and_bool(bool other){
        return (this.x != 0) && other;
    }
}

// Copy of C++ cout
class iostream {
    uint8 pad;

    iostream __shl_str(char* str){
        print("%s", str);
    }

    iostream __shl_int(int i){
        print("%i", i);
    }

    iostream __shl_bool(int b){
        print("%b", b);
    }

    iostream __shl_char(char c){
        print("%c", c);
    }

    iostream __shl_float(double f){
        print("%g", f);
    }

    iostream __shl_string(string s){
        s.print();
    }
}
#define endl '\n'
iostream cout;

int main(uint argc, char** argv){
    double pi = PI;
    double almost_pi = 3.14153;

    int arr[10] = [5, 2, 1, 6, 8];

    if(pi ~= almost_pi)
        println("%*f ~= %*f ± %f", 10, pi, 10, almost_pi, FP_PRECISION);

    frame("Foo tierlist", "1. Foo", "2. Bar", "3. Foo-bar");

    test a = test{6, , test2{"Hello world!", "Foo bar"}};
    test.print(a);
    test.print(test.get());

    string s = string.from_str("Hello world!");
    s.print_debug();

    s.free();   // Free that string (does nothing since its on the stack)

    // Creates a formatted string (on the heap)
    s = string.format("Hello %s!", "friend");
    s.print_debug();

    // Shares the string (increases reference counter)
    string s2 = string.from_shared(&s);
    s2.slice(6, 0);
    s2.print_debug();

    // We copy the string to perform destructive operation
    // (decreases reference counter)
    s2.replace('!', '?');
    s2.print_debug();

    s2.free();  // Free your strings buddy
    s.free();

    // Temporary variable
    int x;

    // Vector of integers
    vector ints = vector.new(sizeof(int));

    x = 5;
    ints.pushback(&x);

    x = 10;
    ints.pushback(&x);

    print_int_vector(&ints);

    x = -5;
    ints.insert(1, &x);

    print_int_vector(&ints);

    ints.remove(0);
    print_int_vector(&ints);

    ints.free();    // Never forget to free your shit

    // Can contain any message
    msg m = msg{};
    m.print();

    m.set_text("Hello world!");
    m.print();

    m.set_number(6.67);
    m.print();

    m.set_confirm(false);
    m.print();

    // Inheritance / polymorphism testing
    Child c = Child{5, 7, 1};
    c.print();
    c.test();

    Child2 c2 = Child2{};
    c2.test();

    Child* c2_c = &c2;
    c2_c.test();        // Now the method Child.test should be overriden by Child2.test

    // Test magic methods
    println("%i, %i, %i, %i, %b",
        OperatorTest{2} + 5,
        OperatorTest{10} * 6.7,
        OperatorTest{16} / OperatorTest{2},
        -OperatorTest{25},
        OperatorTest{0} & true
    );

    cout << "Hello world " << 42 << " " << true << " " << 105.912 << endl;

    try{
        try{
            for(int i = 0; i < 100; i++){
                if(i == 67)
                    throw i;
            }
        }catch(id){
            println("Caught exception %i inside try ... catch", id);
            throw -1, "Shut up kid";
        }
    }catch(id, msg)
        println("Exception %i caught : %s", id, msg);
}
