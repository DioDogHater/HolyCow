RLAPI int32 GetPixelDataSize(int32 width, int32 height, int32 format);              // Get pixel data size in bytes for certain format

//------------------------------------------------------------------------------------
// Font Loading and Text Drawing Functions (Module: text)
//------------------------------------------------------------------------------------

// Font loading/unloading functions
RLAPI Font GetFontDefault();                                                            // Get the default Font
RLAPI Font LoadFont( char *fileName);                                                  // Load font from file into GPU memory (VRAM)
RLAPI Font LoadFontEx( char *fileName, int32 fontSize, int32 *codepoints, int32 codepointCount); // Load font from file with extended parameters, use NULL for codepoints and 0 for codepointCount to load the default character set, font size is provided in pixels height
RLAPI Font LoadFontFromImage(Image image, Color key, int32 firstChar);                        // Load font from Image (XNA style)
RLAPI Font LoadFontFromMemory( char *fileType,  char *fileData, int32 dataSize, int32 fontSize, int32 *codepoints, int32 codepointCount); // Load font from memory buffer, fileType refers to extension: i.e. '.ttf'
RLAPI bool IsFontValid(Font font);                                                          // Check if a font is valid (font data loaded, WARNING: GPU texture not checked)
RLAPI GlyphInfo *LoadFontData( char *fileData, int32 dataSize, int32 fontSize, int32 *codepoints, int32 codepointCount, int32 type); // Load font data for further use
RLAPI Image GenImageFontAtlas( GlyphInfo *glyphs, Rectangle **glyphRecs, int32 glyphCount, int32 fontSize, int32 padding, int32 packMethod); // Generate image font atlas using chars info
RLAPI void UnloadFontData(GlyphInfo *glyphs, int32 glyphCount);                               // Unload font chars info data (RAM)
RLAPI void UnloadFont(Font font);                                                           // Unload font from GPU memory (VRAM)
RLAPI bool ExportFontAsCode(Font font,  char *fileName);                               // Export font as code file, returns true on success

// Text drawing functions
RLAPI void DrawFPS(int32 posX, int32 posY);                                                     // Draw current FPS
RLAPI void DrawText( char *text, int32 posX, int32 posY, int32 fontSize, Color color);       // Draw text (using default font)
RLAPI void DrawTextEx(Font font,  char *text, Vector2 position, float fontSize, float spacing, Color tint); // Draw text using font and additional parameters
RLAPI void DrawTextPro(Font font,  char *text, Vector2 position, Vector2 origin, float rotation, float fontSize, float spacing, Color tint); // Draw text using Font and pro parameters (rotation)
RLAPI void DrawTextCodepoint(Font font, int32 codepoint, Vector2 position, float fontSize, Color tint); // Draw one character (codepoint)
RLAPI void DrawTextCodepoints(Font font,  int32 *codepoints, int32 codepointCount, Vector2 position, float fontSize, float spacing, Color tint); // Draw multiple character (codepoint)

// Text font info functions
RLAPI void SetTextLineSpacing(int32 spacing);                                                 // Set vertical line spacing when drawing with line-breaks
RLAPI int32 MeasureText( char *text, int32 fontSize);                                      // Measure string width for default font
RLAPI Vector2 MeasureTextEx(Font font,  char *text, float fontSize, float spacing);    // Measure string size for Font
RLAPI int32 GetGlyphIndex(Font font, int32 codepoint);                                          // Get glyph index position in font for a codepoint32 (unicode character), fallback to '?' if not found
RLAPI GlyphInfo GetGlyphInfo(Font font, int32 codepoint);                                     // Get glyph font info data for a codepoint32 (unicode character), fallback to '?' if not found
RLAPI Rectangle GetGlyphAtlasRec(Font font, int32 codepoint);                                 // Get glyph rectangle in font atlas for a codepoint32 (unicode character), fallback to '?' if not found

// Text codepoints management functions (unicode characters)
RLAPI char *LoadUTF8( int32 *codepoints, int32 length);                // Load UTF-8 text encoded from codepoints array
RLAPI void UnloadUTF8(char *text);                                      // Unload UTF-8 text encoded from codepoints array
RLAPI int32 *LoadCodepoints( char *text, int32 *count);                // Load all codepoints from a UTF-8 text string, codepoints count returned by parameter
RLAPI void UnloadCodepoints(int32 *codepoints);                           // Unload codepoints data from memory
RLAPI int32 GetCodepointCount( char *text);                          // Get total number of codepoints in a UTF-8 encoded string
RLAPI int32 GetCodepoint( char *text, int32 *codepointSize);           // Get next codepoint32 in a UTF-8 encoded string, 0x3f('?') is returned on failure
RLAPI int32 GetCodepointNext( char *text, int32 *codepointSize);       // Get next codepoint32 in a UTF-8 encoded string, 0x3f('?') is returned on failure
RLAPI int32 GetCodepointPrevious( char *text, int32 *codepointSize);   // Get previous codepoint32 in a UTF-8 encoded string, 0x3f('?') is returned on failure
RLAPI  char *CodepointToUTF8(int32 codepoint, int32 *utf8Size);        // Encode one codepoint32 into UTF-8 byte array (array length returned as parameter)

// Text strings management functions (no UTF-8 strings, only byte chars)
// NOTE: Some strings allocate memory internally for returned strings, just be careful!
RLAPI int32 TextCopy(char *dst,  char *src);                                             // Copy one string to another, returns bytes copied
RLAPI bool TextIsEqual( char *text1,  char *text2);                               // Check if two text string are equal
RLAPI uint32 TextLength( char *text);                                            // Get text length, checks for '\0' ending
RLAPI  char *TextFormat( char *text, ...);                                        // Text formatting with variables (sprintf() style)
RLAPI  char *TextSubtext( char *text, int32 position, int32 length);                  // Get a piece of a text string
RLAPI char *TextReplace( char *text,  char *replace,  char *by);             // Replace text string (WARNING: memory must be freed!)
RLAPI char *TextInsert( char *text,  char *insert, int32 position);                 // Insert text in a position (WARNING: memory must be freed!)
RLAPI  char *TextJoin( char **textList, int32 count,  char *delimiter);        // Join text strings with delimiter
RLAPI  char **TextSplit( char *text, char delimiter, int32 *count);                 // Split text into multiple strings
RLAPI void TextAppend(char *text,  char *append, int32 *position);                       // Append text at specific position and move cursor!
RLAPI int32 TextFindIndex( char *text,  char *find);                                // Find first text occurrence within a string
RLAPI  char *TextToUpper( char *text);                      // Get upper case version of provided string
RLAPI  char *TextToLower( char *text);                      // Get lower case version of provided string
RLAPI  char *TextToPascal( char *text);                     // Get Pascal case notation version of provided string
RLAPI  char *TextToSnake( char *text);                      // Get Snake case notation version of provided string
RLAPI  char *TextToCamel( char *text);                      // Get Camel case notation version of provided string

RLAPI int32 TextToInteger( char *text);                            // Get integer value from text (negative values not supported)
RLAPI float TextToFloat( char *text);                            // Get float value from text (negative values not supported)

