RLAPI int32 GetTouchY();                                    // Get touch position Y for touch point32 0 (relative to screen size)
RLAPI Vector2 GetTouchPosition(int32 index);                    // Get touch position XY for a touch point32 index (relative to screen size)
RLAPI int32 GetTouchPointId(int32 index);                         // Get touch point32 identifier for given index
RLAPI int32 GetTouchPointCount();                           // Get number of touch points

